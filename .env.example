# ─────────────────────────────────────────────────────────────────────────────
# AML Transaction Monitoring - Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Data directory (path to IBM AML dataset CSV files)
DATA_DIR=./data

# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (Claude) API key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key (alternative to Anthropic)
OPENAI_API_KEY=your-openai-api-key-here

# MLflow experiment tracking URI
MLFLOW_TRACKING_URI=mlruns

# Neo4j graph database (optional, for production graph persistence)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
